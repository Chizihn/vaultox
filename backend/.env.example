# ──────────────────────────────────────────────────────────────
# VaultOX Backend — Environment Variables
# Copy this file to .env and fill in the values before running.
# ──────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
SIX_ENABLED=true
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY
# Optional but recommended: required when approving below policy-recommended tier
ADMIN_OVERRIDE_API_KEY=CHANGE_ME_SECOND_APPROVER_KEY

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://vaultox:password@localhost:5432/vaultox
DATABASE_SSL=false

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Solana ───────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# Program IDs — update after Solana Playground deployment
COMPLIANCE_REGISTRY_PROGRAM_ID=5iRF8NUVhQuTGNd4Thndc4LA3PGShfgmKvWX4C25JAuG
VAULT_PROGRAM_ID=5iRF8NUVhQuTGNd4Thndc4LA3PGShfgmKvWX4C25JAuG
SETTLEMENT_ENGINE_PROGRAM_ID=5iRF8NUVhQuTGNd4Thndc4LA3PGShfgmKvWX4C25JAuG
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Server-side keypair for signing on-chain transactions.
# Supported formats:
# 1) base58 secret key string
# 2) byte array string, e.g. "[35,178,...]"
# Generate with: solana-keygen new --no-outfile
BACKEND_WALLET_PRIVATE_KEY=CHANGE_ME_BASE58_KEYPAIR

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://vaultox.finance

# ── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── AML Provider (stub for hackathon) ────────────────────────
# NOTE: current AML implementation is local policy logic.
# AML_PROVIDER_URL / AML_PROVIDER_KEY are placeholders for future external vendor wiring.
AML_PROVIDER_URL=https://api.chainalysis.com
AML_PROVIDER_KEY=CHANGE_ME
# AML strategy selector:
# - deterministic (recommended for local testing): wallet-derived scoring fallback
# - allowlist: classify wallets using AML_FLAGGED_WALLETS / AML_REVIEW_WALLETS
AML_PROVIDER_STRATEGY=deterministic
# Human-readable provider label persisted in aml_screenings.provider
AML_PROVIDER_NAME=PolicyAmlProvider
# Optional when AML_PROVIDER_STRATEGY=allowlist (comma-separated wallet addresses)
AML_FLAGGED_WALLETS=
AML_REVIEW_WALLETS=

# ── KYT Policy Provider ──────────────────────────────────────
# NOTE: current KYT provider is policy-based (no external API key required).
KYT_PROVIDER_NAME=PolicyKytProvider
# Comma-separated wallet addresses for deterministic policy checks
KYT_BLOCKED_WALLETS=
KYT_REVIEW_WALLETS=
# Thresholds expressed in USDC units
KYT_REVIEW_THRESHOLD_USDC=500000
KYT_BLOCK_THRESHOLD_USDC=5000000

# ── Microsoft Entra Adapter ──────────────────────────────────
# Used by /auth/verify-entra-adapter only.
# For local testing without Entra tokens, you can leave this section blank.
# If you do test Entra verification, set ENTRA_TENANT_ID at minimum,
# or explicitly provide ENTRA_JWKS_URL / ENTRA_OPENID_CONFIG_URL.
ENTRA_ISSUER=
ENTRA_AUDIENCE=
ENTRA_TENANT_ID=
# JWKS resolution: set one of these (or ENTRA_TENANT_ID)
ENTRA_JWKS_URL=
ENTRA_OPENID_CONFIG_URL=
# JWKS cache TTL in seconds
ENTRA_JWKS_CACHE_TTL_SEC=300
# Claim name carrying bound wallet address (default walletAddress)
ENTRA_WALLET_CLAIM=walletAddress
# Binding-policy toggles
# true = requested wallet must match wallet claim in token
ENTRA_REQUIRE_WALLET_CLAIM_MATCH=true
# true = create subject<->wallet binding automatically on first successful verify
ENTRA_AUTO_BIND_ON_VERIFY=true
# false = revoked pair cannot be rebound unless manually changed
ENTRA_ALLOW_REBIND_AFTER_REVOCATION=false

# ── SIX Institutional Data ───────────────────────────────────
SIX_API_BASE_URL=https://api.six-group.com
SIX_ENABLED=true
# Required (PEM pair only)
# SIX_CERT_PEM should come from signed-certificate.pem
# SIX_KEY_PEM should come from private-key.pem
# Do NOT use CSR.pem
# Paste full PEM values; if single-line, use \n for line breaks.
SIX_CERT_PEM=
SIX_KEY_PEM=
# Alternative: provide file paths instead of inline PEM content
SIX_CERT_PEM_PATH=
SIX_KEY_PEM_PATH=

# Optional if private key is encrypted
SIX_KEY_PASSPHRASE=

# ── Email / SMTP Configuration ───────────────────────────────
# Generic SMTP configuration (works with any SMTP provider: Gmail, SendGrid, AWS SES, etc.)
# Leave empty to disable email notifications.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_SMTP_EMAIL
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@vaultox.finance
# For Gmail: use App Password (not regular password)
# Generate at: https://myaccount.google.com/apppasswords
