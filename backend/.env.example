# ──────────────────────────────────────────────────────────────
# VaultOX Backend — Environment Variables
# Copy this file to .env and fill in the values before running.
# ──────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://vaultox:password@localhost:5432/vaultox
DATABASE_SSL=false

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Solana ───────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# Program IDs — update after Solana Playground deployment
COMPLIANCE_REGISTRY_PROGRAM_ID=5iRF8NUVhQuTGNd4Thndc4LA3PGShfgmKvWX4C25JAuG
VAULT_PROGRAM_ID=5iRF8NUVhQuTGNd4Thndc4LA3PGShfgmKvWX4C25JAuG
SETTLEMENT_ENGINE_PROGRAM_ID=5iRF8NUVhQuTGNd4Thndc4LA3PGShfgmKvWX4C25JAuG
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Server-side keypair for signing on-chain transactions.
# Supported formats:
# 1) base58 secret key string
# 2) byte array string, e.g. "[35,178,...]"
# Generate with: solana-keygen new --no-outfile
BACKEND_WALLET_PRIVATE_KEY=CHANGE_ME_BASE58_KEYPAIR

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://vaultox.finance

# ── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── AML Provider (stub for hackathon) ────────────────────────
AML_PROVIDER_URL=https://api.chainalysis.com
AML_PROVIDER_KEY=CHANGE_ME
